# Copy this file to .env and fill in real values. NEVER commit the real .env.

# Stripe SECRET key - server-only. Get one at:
#   https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_replace_me

# Stripe PUBLISHABLE key - safe to expose in the browser.
# This must match the value hardcoded in app.js at CONFIG.stripePublicKey.
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Webhook signing secret. For local dev get it from:
#   stripe listen --forward-to localhost:4242/webhook
# For production, copy it from the webhook endpoint you create in the
# Stripe dashboard (Developers -> Webhooks -> your endpoint -> Signing secret).
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Local server port.
PORT=4242
